ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false

SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_TOTP_SECRET=replace-with-base32-secret
ADMIN_TOTP_ISSUER=智能门禁系统

DATABASE_URL=sqlite:////data/access_control.db

CORS_ORIGINS=https://your-pages-domain.pages.dev,https://door.example.com
ALLOWED_HOSTS=api.example.com

AUTO_SEED_DEFAULT_USERS=false
AUTO_SEED_DEMO_DATA=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_OPERATOR_USERNAME=operator
SEED_OPERATOR_PASSWORD=replace-with-strong-operator-password

ACCESS_TOKEN_EXPIRE_MINUTES=30
LOGIN_RATE_LIMIT_PER_MINUTE=8
LOGIN_LOCKOUT_SECONDS=180