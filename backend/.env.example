# Copy to `.env` and update values before public exposure.

ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=false

# Set a random secret with at least 32 chars.
SECRET_KEY=replace-with-a-long-random-secret

# Example:
# CORS_ORIGINS=https://your-frontend.example.com
# ALLOWED_HOSTS=api.yourdomain.com
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
ALLOWED_HOSTS=127.0.0.1,localhost

# Admin login TOTP secret (generate via scripts/generate_admin_totp.py)
ADMIN_TOTP_SECRET=replace-with-base32-secret
ADMIN_TOTP_ISSUER=智能门禁系统

# Disable by default. Enable only for local bootstrapping.
AUTO_SEED_DEFAULT_USERS=false
AUTO_SEED_DEMO_DATA=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-strong-password-12+
SEED_OPERATOR_USERNAME=operator
SEED_OPERATOR_PASSWORD=replace-with-strong-password-12+

ACCESS_TOKEN_EXPIRE_MINUTES=30
LOGIN_RATE_LIMIT_PER_MINUTE=8
LOGIN_LOCKOUT_SECONDS=180
